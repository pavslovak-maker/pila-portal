# =============================================================================
# Portál pily — šablona proměnných prostředí
# =============================================================================
# Jak použít (pro začátečníka):
# 1) Zkopírujte tento soubor a pojmenujte kopii ".env" (bez .example).
# 2) Vyplňte hodnoty postupně — u MVP stačí nejdřív DATABASE_URL (krok 2).
# 3) Soubor .env se do gitu necommituje (obsahuje tajné klíče).
# =============================================================================

# --- Databáze (PostgreSQL — Neon nebo Supabase, free tier) ---
# Potřebné od kroku 2 (datový model). Zatím můžete nechat prázdné.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# --- Stripe (platby kartou) — nastavíme později, nepotřebné pro první kroky ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# --- E-mail (Resend) — notifikace majiteli, nastavíme v kroku 7 ---
RESEND_API_KEY="re_..."
OWNER_EMAIL="majitel@pila.cz"

# --- Telegram (volitelný druhý kanál notifikací) ---
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# --- Úložiště fotek (Cloudflare R2 / AWS S3) — krok s uploadem pořezu ---
S3_ENDPOINT=""
S3_BUCKET="pila-uploads"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL=""

# --- Admin přístup (magic link) — krok 8 ---
ADMIN_EMAIL="majitel@pila.cz"
AUTH_SECRET=""

# --- Sentry (monitoring chyb) — při nasazení ---
SENTRY_DSN=""

# --- Veřejné údaje na webu (volitelné, bez placených služeb) ---
NEXT_PUBLIC_SITE_PHONE="+420000000000"
NEXT_PUBLIC_SITE_NAME="Pila"
